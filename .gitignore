# Embedded repositories and CPython worktrees keep their own history.
/cpython/
/cpython-lane5/
/cpython-upstream-main/
/package-manager/
/worktrees/

# Official binary/runtime distributions and generated artifacts.
/official-python/
/artifacts/**
!/artifacts/
!/artifacts/plans/
!/artifacts/plans/**/*.md
!/artifacts/receipts/
!/artifacts/receipts/**/*.md
!/artifacts/reports/
!/artifacts/reports/**/*.md

# Benchmark output is reproducible; keep benchmark source only.
/benchmarks/runs/
/benchmarks/__pycache__/

# Python caches and virtual environments.
**/__pycache__/
**/*.py[cod]
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.cache/
**/.venv/
**/venv/

# Build outputs and package-manager artifacts.
**/target/
**/build/
**/dist/
**/node_modules/
**/externals/
**/Lib/site-packages/

# Local environment and editor files.
.env
.env.*
!.env.example
.vscode/
.idea/
*.swp
*.swo
Thumbs.db
Desktop.ini
